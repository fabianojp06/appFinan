import React, { useState, useEffect, useCallback, useContext } from 'react';
import { View, Text, TextInput, TouchableOpacity, ScrollView, Alert, ActivityIndicator } from 'react-native';
import { supabase } from '../services/supabase';
import { ThemeContext } from '../contexts/ThemeContext'; // Importando o Contexto
import { ArrowUpCircle, ArrowDownCircle, Tag, AlignLeft, DollarSign, Calendar } from 'lucide-react-native';

export default function AddTransactionScreen() {
  // Consome o tema global
  const { isDark } = useContext(ThemeContext);

  const [amount, setAmount] = useState('');
  const [description, setDescription] = useState('');
  const [category, setCategory] = useState(null);
  const [type, setType] = useState('expense'); // 'income' ou 'expense'
  const [loading, setLoading] = useState(false);
  const [categories, setCategories] = useState([]);

  // --- VARIÁVEIS DE COR DINÂMICAS ---
  const bgMain = isDark ? 'bg-slate-950' : 'bg-slate-50';
  const bgCard = isDark ? 'bg-slate-900' : 'bg-white';
  const bgInput = isDark ? 'bg-slate-800' : 'bg-slate-100';
  const borderCard = isDark ? 'border-slate-800' : 'border-slate-200';
  const textTitle = isDark ? 'text-white' : 'text-slate-900';
  const textSub = isDark ? 'text-slate-400' : 'text-slate-500';
  const placeholderColor = isDark ? '#64748b' : '#94a3b8';

  const fetchCategories = useCallback(async () => {
    const { data: { user } } = await supabase.auth.getUser();
    if (user) {
      const { data, error } = await supabase
        .from('categories')
        .select('*')
        .eq('user_id', user.id)
        .eq('type', type); // Filtra categorias pelo tipo selecionado
      if (!error && data) setCategories(data);
    }
  }, [type]);

  useEffect(() => {
    fetchCategories();
  }, [fetchCategories]);

  const handleSave = async () => {
    if (!amount || !category) {
      Alert.alert('Erro', 'Por favor, preencha o valor e selecione uma categoria.');
      return;
    }

    setLoading(true);
    try {
      const { data: { user } } = await supabase.auth.getUser();
      if (!user) throw new Error('Usuário não autenticado.');

      const { error } = await supabase.from('transactions').insert([
        {
          user_id: user.id,
          amount: parseFloat(amount.replace(',', '.')),
          description: description.trim(),
          category_id: category.id,
          type: type,
          created_at: new Date().toISOString(),
        },
      ]);

      if (error) throw error;

      Alert.alert('Sucesso!', 'Lançamento realizado com sucesso.');
      setAmount('');
      setDescription('');
      setCategory(null);
    } catch (error) {
      Alert.alert('Erro', error.message);
    } finally {
      setLoading(false);
    }
  };

  return (
    <ScrollView className={`flex-1 ${bgMain}`}>
      <View className="max-w-3xl mx-auto w-full p-6 pb-20">
        
        <View className="pt-10 mb-8">
          <Text className={`text-3xl font-extrabold ${textTitle}`}>Novo Lançamento</Text>
          <Text className={`text-sm mt-1 ${textSub}`}>Registre suas movimentações financeiras.</Text>
        </View>

        {/* SELETOR DE TIPO (RECEITA / DESPESA) */}
        <View className={`flex-row p-1 rounded-2xl mb-8 border ${bgInput} ${borderCard}`}>
          <TouchableOpacity 
            onPress={() => { setType('expense'); setCategory(null); }}
            className={`flex-1 flex-row items-center justify-center py-4 rounded-xl ${type === 'expense' ? 'bg-red-500 shadow-lg' : ''}`}
          >
            <ArrowDownCircle size={20} color={type === 'expense' ? '#fff' : '#ef4444'} />
            <Text className={`ml-2 font-bold ${type === 'expense' ? 'text-white' : 'text-red-500'}`}>Despesa</Text>
          </TouchableOpacity>

          <TouchableOpacity 
            onPress={() => { setType('income'); setCategory(null); }}
            className={`flex-1 flex-row items-center justify-center py-4 rounded-xl ${type === 'income' ? 'bg-green-600 shadow-lg' : ''}`}
          >
            <ArrowUpCircle size={20} color={type === 'income' ? '#fff' : '#22c55e'} />
            <Text className={`ml-2 font-bold ${type === 'income' ? 'text-white' : 'text-green-600'}`}>Receita</Text>
          </TouchableOpacity>
        </View>

        {/* CAMPO: VALOR */}
        <View className="mb-6">
          <Text className={`text-sm font-bold mb-2 ml-1 ${textSub}`}>Valor do Lançamento</Text>
          <View className={`flex-row items-center px-4 rounded-2xl border ${bgInput} ${borderCard}`}>
            <DollarSign size={20} color={placeholderColor} />
            <TextInput
              className={`flex-1 py-4 px-2 text-xl font-bold ${textTitle}`}
              placeholder="0,00"
              placeholderTextColor={placeholderColor}
              keyboardType="numeric"
              value={amount}
              onChangeText={setAmount}
            />
          </View>
        </View>

        {/* CAMPO: DESCRIÇÃO */}
        <View className="mb-6">
          <Text className={`text-sm font-bold mb-2 ml-1 ${textSub}`}>Descrição (Opcional)</Text>
          <View className={`flex-row items-center px-4 rounded-2xl border ${bgInput} ${borderCard}`}>
            <AlignLeft size={20} color={placeholderColor} />
            <TextInput
              className={`flex-1 py-4 px-2 text-base ${textTitle}`}
              placeholder="Ex: Aluguel, Compras do mês..."
              placeholderTextColor={placeholderColor}
              value={description}
              onChangeText={setDescription}
            />
          </View>
        </View>

        {/* SELETOR: CATEGORIAS */}
        <View className="mb-10">
          <Text className={`text-sm font-bold mb-3 ml-1 ${textSub}`}>Selecione a Categoria</Text>
          <View className="flex-row flex-wrap">
            {categories.length === 0 ? (
              <Text className={`italic text-xs p-2 ${textSub}`}>Nenhuma categoria de {type === 'expense' ? 'despesa' : 'receita'} encontrada.</Text>
            ) : (
              categories.map((cat) => (
                <TouchableOpacity 
                  key={cat.id}
                  onPress={() => setCategory(cat)}
                  className={`flex-row items-center px-4 py-3 rounded-full border mr-2 mb-2 ${
                    category?.id === cat.id ? 'bg-blue-600 border-blue-500' : `${bgCard} ${borderCard}`
                  }`}
                >
                  <View style={{ backgroundColor: cat.color }} className="w-3 h-3 rounded-full mr-2" />
                  <Text className={`font-semibold ${category?.id === cat.id ? 'text-white' : textTitle}`}>
                    {cat.name}
                  </Text>
                </TouchableOpacity>
              ))
            )}
          </View>
        </View>

        {/* BOTÃO SALVAR */}
        <TouchableOpacity 
          onPress={handleSave}
          disabled={loading}
          className={`py-5 rounded-2xl items-center shadow-xl ${loading ? 'bg-slate-700' : 'bg-blue-600'}`}
        >
          {loading ? (
            <ActivityIndicator color="#fff" />
          ) : (
            <Text className="text-white font-extrabold text-lg">Confirmar Lançamento</Text>
          )}
        </TouchableOpacity>

      </View>
    </ScrollView>
  );
}